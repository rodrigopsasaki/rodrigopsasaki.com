---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects', ({ data }) => data.visible === true);
// Filter out integration pages (those with a parent field)
const topLevelProjects = projects.filter(project => !project.data.parent);
const sortedProjects = topLevelProjects.sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return (a.data.order ?? 999) - (b.data.order ?? 999);
});
---

<Layout title="Projects">
  <div class="min-h-screen">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <!-- Header -->
      <div class="mb-10">
        <h1 class="text-3xl font-bold" style="color: var(--c-text)">
          Projects
        </h1>
      </div>

      <!-- Projects List -->
      <div class="space-y-6">
        {sortedProjects.length === 0 ? (
          <p style="color: var(--c-text-muted)">
            No projects yet.
          </p>
        ) : (
          sortedProjects.map((project) => (
            <article class="pb-6" style="border-bottom: 1px solid var(--c-border)">
              <!-- Project title and links -->
              <div class="flex items-start justify-between gap-4 mb-2">
                <h2 class="text-base font-semibold" style="color: var(--c-text)">
                  <a
                    href={`/projects/${project.slug}/`}
                    class="transition-colors duration-150 hover:opacity-80"
                    style="color: var(--c-text)"
                  >
                    {project.data.title}
                  </a>
                </h2>

                <div class="flex gap-2 flex-shrink-0">
                  {project.data.github && (
                    <a
                      href={project.data.github}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="transition-colors duration-150 p-0.5 hover:opacity-80"
                      aria-label="GitHub repository"
                      style="color: var(--c-text-muted)"
                    >
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 0C4.477 0 0 4.484 0 10.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0110 4.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0020 10.017C20 4.484 15.522 0 10 0z" clip-rule="evenodd"></path>
                      </svg>
                    </a>
                  )}
                  {project.data.demo && (
                    <a
                      href={project.data.demo}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="transition-colors duration-150 p-0.5 hover:opacity-80"
                      aria-label="Live demo"
                      style="color: var(--c-text-muted)"
                    >
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                      </svg>
                    </a>
                  )}
                </div>
              </div>

              <p class="text-sm mb-3 leading-relaxed" style="color: var(--c-text-muted)">
                {project.data.description}
              </p>

              <!-- Tags -->
              <div class="flex flex-wrap gap-1.5">
                {project.data.tags.map((tag: string) => (
                  <span
                    class="text-xs px-2 py-0.5 rounded"
                    style="background-color: var(--c-tag-bg); color: var(--c-tag-text)"
                  >
                    {tag}
                  </span>
                ))}
              </div>
            </article>
          ))
        )}
      </div>
    </div>
  </div>
</Layout>
