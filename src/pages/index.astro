---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { snap } from '../data/now';

// Real content
const allPosts = await getCollection('blog', ({ data }) => data.visible === true);
const recentPosts = allPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 5);
const latestPost = recentPosts[0];
const essayCount = allPosts.length;

const allProjects = await getCollection('projects', ({ data }) => data.visible === true);
const topLevelProjects = allProjects.filter(p => !p.data.parent);
const projectCount = topLevelProjects.length;

// Condensed "Now · live" sidebar: one line per populated block. Derives from
// the same snap data as the /now page, so nothing can drift. We skip the
// `elsewhere` block here because it's work/personal context — better
// expanded on /now than flashed in the home sidebar.
const nowRows = snap.blocks
  .filter(b => b.label !== 'elsewhere')
  .map(b => {
    const first = b.items[0];
    return {
      kind: b.label,
      text: first ? first.name : 'nothing right now',
      muted: !first,
    };
  });

// Workspace tree (real essays + projects)
type TreeItem = { label: string; depth: number; muted: boolean; href?: string };
const tree: TreeItem[] = [
  { label: '▾ essays/',   depth: 0, muted: false },
  ...recentPosts.slice(0, 5).map(p => ({
    label: `   ${p.slug}.md`, depth: 1, muted: true, href: `/blog/${p.slug}/`,
  })),
  { label: '▾ projects/',  depth: 0, muted: false },
  ...topLevelProjects.slice(0, 4).map(p => ({
    label: `   ${p.slug}.md`, depth: 1, muted: true, href: `/projects/${p.slug}/`,
  })),
  { label: '▸ cv/',        depth: 0, muted: false, href: '/cv/' },
];

// Recent commits (derived from the 5 most recent essays; real dates, compact labels)
function ago(iso: string): string {
  const d = Math.floor((Date.now() - new Date(iso).getTime()) / 86_400_000);
  if (d < 1) return 'today';
  if (d < 7) return `${d}d ago`;
  if (d < 30) return `${Math.floor(d / 7)}w ago`;
  if (d < 365) return `${Math.floor(d / 30)}mo ago`;
  return `${Math.floor(d / 365)}y ago`;
}
function shortHash(seedStr: string): string {
  let h = 0;
  for (let i = 0; i < seedStr.length; i++) h = (h * 31 + seedStr.charCodeAt(i)) | 0;
  const hex = (h >>> 0).toString(16).padStart(7, '0');
  return hex.slice(0, 7);
}
// Conventional-commits style: `essay(slug): action`. No em-dashes.
const commits = recentPosts.slice(0, 5).map((p, i) => ({
  hash: shortHash(p.slug),
  t: ago(p.data.date),
  msg: `essay(${p.slug}): ${i === 0 ? 'publish' : i === 1 ? 'revise' : 'add'}`,
  accent: ['green', 'amber', 'green', 'blue', 'amber'][i % 5],
}));

const LATEST_DATE = latestPost ? new Date(latestPost.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : '';
---

<Layout
  title="Home"
  active="home"
  statusLeft="readme · 1:1"
  statusCenter="✓ 0 errors"
>
  <div class="home-grid">
    <!-- Left sidebar: file tree + now -->
    <aside class="home-sidebar">
      <div class="home-section-label">Workspace</div>
      <div class="home-tree">
        {tree.map(item => item.href ? (
          <a href={item.href} class="home-tree__row" data-muted={item.muted ? 'true' : 'false'}>
            {item.depth > 0 && <span class="home-tree__leaf" aria-hidden="true">◆</span>}
            <span class="home-tree__label">{item.label}</span>
          </a>
        ) : (
          <div class="home-tree__row" data-muted={item.muted ? 'true' : 'false'}>
            {item.depth > 0 && <span class="home-tree__leaf" aria-hidden="true">◆</span>}
            <span class="home-tree__label">{item.label}</span>
          </div>
        ))}
      </div>

      <div class="home-section-divider"></div>
      <a href="/now/" class="home-section-label home-section-label--link">
        Now · live <span aria-hidden="true">→</span>
      </a>
      <div class="home-now">
        {nowRows.map(n => (
          <div class="home-now__item">
            <div class="home-now__kind">// {n.kind}</div>
            <div class="home-now__text" data-muted={n.muted ? 'true' : 'false'}>{n.text}</div>
          </div>
        ))}
      </div>
    </aside>

    <!-- Center: hero + quick actions + commits -->
    <section class="home-center">
      <div class="home-prompt">
        <span class="home-prompt__sigil">$</span> cat about.md
      </div>

      <pre class="home-frontmatter">---
name:    Rodrigo Sasaki
role:    Senior Software Engineer
since:   2009
tz:      America/Sao_Paulo  // UTC-3
---</pre>

      <h1 class="home-headline">
        I build software that <span class="home-headline__accent">stays simple</span> on purpose.<br />
        I write about how hard that is.
      </h1>

      <p class="home-lede">
        15+ years in backend and infrastructure. Now learning to
        leverage AI to its full potential.
      </p>

      <div class="home-actions">
        {latestPost && (
          <a href={`/blog/${latestPost.slug}/`} class="home-action" data-accent="green">
            <div class="home-action__kind">→ read</div>
            <div class="home-action__label">Latest essay</div>
            <div class="home-action__sub">{latestPost.slug}.md</div>
          </a>
        )}
        <a href="/projects/vision/" class="home-action" data-accent="amber">
          <div class="home-action__kind">→ try</div>
          <div class="home-action__label">Install vision</div>
          <div class="home-action__sub">npm i @rodrigopsasaki/vision</div>
        </a>
        <a href="/cv/" class="home-action" data-accent="blue">
          <div class="home-action__kind">→ hire</div>
          <div class="home-action__label">Read the CV</div>
          <div class="home-action__sub">cv.md · PDF available</div>
        </a>
      </div>

      <div class="home-section-label home-commits__label">Recent commits</div>
      <div class="home-commits">
        {commits.map(c => (
          <div class="home-commits__row">
            <span class="home-commits__hash" data-accent={c.accent}>{c.hash}</span>
            <span class="home-commits__time">{c.t}</span>
            <span class="home-commits__msg">{c.msg}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Right rail: latest + stats + mosaic -->
    <aside class="home-rail">
      {latestPost && (
        <div>
          <div class="home-section-label">// latest essay</div>
          <a href={`/blog/${latestPost.slug}/`} class="home-rail__title">
            {latestPost.data.title}
          </a>
          <div class="home-rail__sub">{latestPost.data.description}</div>
          <div class="home-rail__meta">
            {LATEST_DATE} · <a href={`/blog/${latestPost.slug}/`} class="home-rail__cta">open →</a>
          </div>
        </div>
      )}

      <div>
        <div class="home-section-label">// by the numbers</div>
        <div class="home-stats">
          <div class="home-stats__cell">
            <div class="home-stats__num">15+</div>
            <div class="home-stats__lbl">yrs exp</div>
          </div>
          <div class="home-stats__cell">
            <div class="home-stats__num">{essayCount}</div>
            <div class="home-stats__lbl">essays</div>
          </div>
          <div class="home-stats__cell">
            <div class="home-stats__num">{projectCount}</div>
            <div class="home-stats__lbl">OSS libs</div>
          </div>
          <div class="home-stats__cell">
            <div class="home-stats__num">5</div>
            <div class="home-stats__lbl">roles</div>
          </div>
        </div>
      </div>

      <div>
        <div class="home-section-label">// elsewhere</div>
        <ul class="home-links">
          <li><a href="https://github.com/rodrigopsasaki" target="_blank" rel="noopener noreferrer">github.com/rodrigopsasaki <span aria-hidden="true">↗</span></a></li>
          <li><a href="https://www.linkedin.com/in/rodrigopsasaki" target="_blank" rel="noopener noreferrer">linkedin/in/rodrigopsasaki <span aria-hidden="true">↗</span></a></li>
        </ul>
      </div>
    </aside>
  </div>
</Layout>

<style>
  .home-grid {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr) 280px;
    min-height: calc(100vh - 40px - 28px);
  }
  @media (max-width: 1024px) {
    .home-grid { grid-template-columns: 200px minmax(0, 1fr); }
    .home-rail { display: none; }
  }
  @media (max-width: 767px) {
    .home-grid { grid-template-columns: 1fr; }
    .home-sidebar { display: none; }
  }

  /* ───── Sidebar ───────────────────────────────────────────── */
  .home-sidebar {
    border-right: 1px solid var(--c-border);
    padding: 16px 0;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12px;
  }
  .home-section-label {
    padding: 0 16px 10px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--c-text-muted);
  }
  a.home-section-label--link {
    display: block;
    transition: color 0.15s;
  }
  a.home-section-label--link:hover { color: var(--c-text); }
  .home-section-divider {
    border-top: 1px solid var(--c-border);
    margin: 20px 0 10px;
  }

  .home-tree { padding: 0 12px; }
  .home-tree__row {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 3px 6px;
    color: var(--c-text);
    border-radius: 3px;
    cursor: default;
  }
  .home-tree__row[data-muted="true"] { color: var(--c-text-secondary); }
  a.home-tree__row { cursor: pointer; }
  a.home-tree__row:hover { color: var(--c-text); background: var(--c-border-soft); }
  .home-tree__leaf { color: var(--c-text-muted); }

  .home-now {
    padding: 0 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .home-now__kind {
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--c-accent);
  }
  .home-now__text {
    font-size: 12px;
    line-height: 1.5;
    color: var(--c-text-secondary);
  }
  .home-now__text[data-muted="true"] {
    color: var(--c-text-muted);
    font-style: italic;
  }

  /* ───── Center ────────────────────────────────────────────── */
  .home-center {
    padding: 64px 56px;
    max-width: 960px;
  }
  @media (max-width: 767px) {
    .home-center { padding: 32px 20px; }
  }

  .home-prompt {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12px;
    color: var(--c-text-muted);
    margin-bottom: 24px;
  }
  .home-prompt__sigil { color: var(--c-accent-amber); }

  .home-frontmatter {
    margin: 0;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 13px;
    color: var(--c-text-muted);
    line-height: 1.7;
    white-space: pre;
  }

  .home-headline {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-weight: 500;
    font-size: clamp(30px, 5vw, 48px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 32px 0 0;
    color: var(--c-text);
    text-wrap: balance;
  }
  .home-headline__accent { color: var(--c-accent); }

  .home-lede {
    font-family: 'Inter', -apple-system, sans-serif;
    font-size: 18px;
    line-height: 1.55;
    color: var(--c-text-secondary);
    margin: 28px 0 0;
    max-width: 680px;
    text-wrap: pretty;
  }

  .home-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin: 36px 0 0;
  }
  .home-action {
    flex: 1 1 220px;
    background: var(--c-bg-card);
    border: 1px solid var(--c-border);
    padding: 16px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12px;
    transition: transform 0.15s, border-color 0.15s;
  }
  .home-action:hover { transform: translateY(-2px); border-color: var(--c-border-strong); }
  .home-action[data-accent="green"] { border-left: 2px solid var(--c-accent); }
  .home-action[data-accent="amber"] { border-left: 2px solid var(--c-accent-amber); }
  .home-action[data-accent="blue"]  { border-left: 2px solid var(--c-accent-blue); }
  .home-action__kind {
    color: var(--c-text-muted);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .home-action__label {
    color: var(--c-text);
    font-size: 15px;
    margin: 6px 0 4px;
    font-family: 'Inter', sans-serif;
    font-weight: 500;
  }
  .home-action__sub {
    color: var(--c-text-secondary);
    font-size: 12px;
  }

  .home-commits__label { margin-top: 48px; padding-left: 0; }
  .home-commits {
    background: var(--c-bg-card);
    border: 1px solid var(--c-border);
    padding: 8px 14px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12px;
    line-height: 2;
  }
  .home-commits__row {
    display: grid;
    grid-template-columns: 80px 70px 1fr;
    gap: 14px;
    color: var(--c-text-secondary);
  }
  .home-commits__hash[data-accent="green"] { color: var(--c-accent); }
  .home-commits__hash[data-accent="amber"] { color: var(--c-accent-amber); }
  .home-commits__hash[data-accent="blue"]  { color: var(--c-accent-blue); }
  .home-commits__time { color: var(--c-text-muted); }

  /* ───── Right rail ────────────────────────────────────────── */
  .home-rail {
    border-left: 1px solid var(--c-border);
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 28px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
  }
  .home-rail .home-section-label { padding: 0 0 10px; }

  .home-rail__title {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    color: var(--c-text);
    font-weight: 500;
    line-height: 1.3;
  }
  .home-rail__title:hover { color: var(--c-accent); }
  .home-rail__sub {
    font-size: 11px;
    color: var(--c-text-secondary);
    margin-top: 6px;
    line-height: 1.6;
  }
  .home-rail__meta {
    margin-top: 10px;
    font-size: 11px;
    color: var(--c-text-muted);
  }
  .home-rail__cta { color: var(--c-accent); }
  .home-rail__cta:hover { color: var(--c-accent-hover); }

  .home-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  .home-stats__cell {
    border-left: 1px solid var(--c-border);
    padding-left: 10px;
  }
  .home-stats__num {
    font-size: 26px;
    font-weight: 500;
    color: var(--c-text);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
  }
  .home-stats__lbl {
    font-size: 10px;
    color: var(--c-text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .home-links {
    margin: 0;
    padding: 0;
    list-style: none;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12px;
    line-height: 2;
  }
  .home-links a {
    color: var(--c-text-secondary);
    transition: color 0.15s;
  }
  .home-links a:hover { color: var(--c-accent); }
</style>
