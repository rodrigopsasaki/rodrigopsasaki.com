---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => data.draft !== true && data.visible === true);
const sorted = posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// Compute reading time (~200 wpm)
function readingMin(body: string): number {
  return Math.max(1, Math.ceil(body.split(/\s+/).length / 200));
}

// Number essays newest → oldest (#1 newest looks like the design)
const rows = sorted.map((p, i) => ({
  slug: p.slug,
  n: sorted.length - i,
  title: p.data.title,
  desc: p.data.description,
  date: p.data.date,
  tags: p.data.tags ?? [],
  read: readingMin(p.body),
  series: p.data.series,
  seriesOrder: p.data.seriesOrder,
  isLatest: i === 0,
}));

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString('en-US', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\//g, '-');
}
---

<Layout
  title="Blog"
  description="Essays on simplicity, state, and the software we ship."
  active="essays"
  statusLeft="essays · list view"
  statusCenter={`${rows.length} items · all visible`}
>
  <section class="essays-hero">
    <div class="essays-hero__crumb">// essays/</div>
    <h1 class="essays-hero__title">
      <span class="essays-hero__sigil">$</span> ls -lt ~/essays
    </h1>
    <p class="essays-hero__sub">
      A long project. Newest first.
    </p>
  </section>

  <!-- Table -->
  <div class="essays-table">
    <div class="essays-table__head">
      <div>id</div>
      <div>title</div>
      <div>tags</div>
      <div>date</div>
      <div class="essays-table__right">read</div>
    </div>
    {rows.map((r, i) => (
      <a href={`/blog/${r.slug}/`} class="essays-table__row" data-latest={r.isLatest ? 'true' : 'false'} data-idx={i}>
        <div class="essays-table__id">#{String(r.n).padStart(2, '0')}</div>
        <div>
          <div class="essays-table__title">
            {r.title}
            {r.isLatest && <span class="essays-table__badge">LATEST</span>}
          </div>
          <div class="essays-table__desc">{r.desc}</div>
          {r.series && (
            <div class="essays-table__series">
              // {r.series}.series · part {(r.seriesOrder ?? 0) + 1}
            </div>
          )}
        </div>
        <div class="essays-table__tags">
          {r.tags.slice(0, 3).map(t => <div>#{t}</div>)}
        </div>
        <div class="essays-table__date">{formatDate(r.date)}</div>
        <div class="essays-table__read">{r.read}m</div>
      </a>
    ))}
  </div>
</Layout>

<script is:inline>
  // j/k move the cursor through essay rows; Enter opens the focused row.
  // Scoped to the essays page only — listener self-unbinds when user
  // navigates away (ClientRouter swap discards DOM).
  (function () {
    function active() {
      return location.pathname === '/blog/' || location.pathname === '/blog';
    }
    function isTyping() {
      var el = document.activeElement;
      if (!el) return false;
      var tag = el.tagName;
      return tag === 'INPUT' || tag === 'TEXTAREA' || el.isContentEditable;
    }

    var cursor = -1;
    function rows() {
      return Array.from(document.querySelectorAll('.essays-table__row'));
    }
    function paint() {
      rows().forEach(function (r, i) {
        if (i === cursor) r.setAttribute('data-cursor', 'true');
        else r.removeAttribute('data-cursor');
      });
    }
    function move(delta) {
      var rs = rows();
      if (!rs.length) return;
      cursor = cursor < 0
        ? (delta > 0 ? 0 : rs.length - 1)
        : (cursor + delta + rs.length) % rs.length;
      paint();
      rs[cursor].scrollIntoView({ block: 'nearest' });
    }
    function open() {
      var rs = rows();
      if (cursor < 0 || !rs[cursor]) return;
      window.location.href = rs[cursor].getAttribute('href');
    }

    document.addEventListener('keydown', function (e) {
      if (!active() || isTyping()) return;
      if (e.metaKey || e.ctrlKey || e.altKey) return;
      if (e.key === 'j' || e.key === 'ArrowDown') { e.preventDefault(); move(1); }
      else if (e.key === 'k' || e.key === 'ArrowUp') { e.preventDefault(); move(-1); }
      else if (e.key === 'Enter' && cursor >= 0) { e.preventDefault(); open(); }
      else if (e.key === 'Escape') { cursor = -1; paint(); }
    });

    // Reset cursor on navigation so it starts fresh each time /blog/ mounts.
    document.addEventListener('astro:page-load', function () {
      cursor = -1;
      paint();
    });
  })();
</script>

<style>
  /* ───── Hero ──────────────────────────────────────────────── */
  .essays-hero {
    padding: 56px 56px 24px;
    max-width: 1100px;
  }
  @media (max-width: 767px) { .essays-hero { padding: 32px 20px 16px; } }

  .essays-hero__crumb {
    color: var(--c-text-muted);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12px;
    margin-bottom: 8px;
  }
  .essays-hero__title {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-weight: 500;
    font-size: clamp(28px, 4.5vw, 44px);
    margin: 0;
    letter-spacing: -0.018em;
    line-height: 1.1;
    color: var(--c-text);
    text-wrap: balance;
  }
  .essays-hero__sigil { color: var(--c-accent); }
  .essays-hero__sub {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    color: var(--c-text-secondary);
    margin-top: 18px;
    max-width: 640px;
    line-height: 1.6;
  }

  /* ───── Table ─────────────────────────────────────────────── */
  .essays-table { padding: 12px 56px 40px; }
  @media (max-width: 767px) { .essays-table { padding: 12px 20px 40px; } }

  .essays-table__head {
    display: grid;
    grid-template-columns: 60px 1fr 160px 120px 80px;
    gap: 16px;
    padding: 10px 12px;
    border-top: 1px solid var(--c-border);
    border-bottom: 1px solid var(--c-border);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--c-text-muted);
  }
  .essays-table__head .essays-table__right { text-align: right; }

  .essays-table__row {
    display: grid;
    grid-template-columns: 60px 1fr 160px 120px 80px;
    gap: 16px;
    padding: 16px 12px;
    border-bottom: 1px solid var(--c-border-soft);
    border-left: 2px solid transparent;
    margin-left: -2px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 13px;
    align-items: baseline;
    color: inherit;
    transition: background-color 0.15s, border-left-color 0.15s;
  }
  .essays-table__row:hover { background: var(--c-border-soft); }
  .essays-table__row[data-latest="true"] { background: var(--c-accent-muted); }
  /* Keyboard cursor for j/k navigation */
  .essays-table__row[data-cursor="true"] {
    border-left-color: var(--c-accent);
    background: var(--c-border-soft);
  }
  .essays-table__row[data-cursor="true"][data-latest="true"] {
    background: var(--c-accent-muted);
  }
  .essays-table__row:focus-visible {
    outline: none;
    border-left-color: var(--c-accent);
  }

  .essays-table__id {
    color: var(--c-text-muted);
    font-variant-numeric: tabular-nums;
  }
  .essays-table__title {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    color: var(--c-text);
    font-weight: 500;
  }
  .essays-table__badge {
    margin-left: 10px;
    font-size: 9px;
    background: var(--c-accent);
    color: var(--c-on-accent);
    padding: 2px 6px;
    border-radius: 2px;
    letter-spacing: 0.1em;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
  }
  .essays-table__desc {
    font-size: 12px;
    color: var(--c-text-secondary);
    margin-top: 4px;
    line-height: 1.5;
    font-family: 'Inter', sans-serif;
  }
  .essays-table__series {
    font-size: 10px;
    color: var(--c-accent-amber);
    margin-top: 4px;
    letter-spacing: 0.08em;
  }
  .essays-table__tags {
    font-size: 11px;
    color: var(--c-text-secondary);
  }
  .essays-table__date {
    font-size: 11px;
    color: var(--c-text-muted);
    font-variant-numeric: tabular-nums;
  }
  .essays-table__read {
    font-size: 11px;
    color: var(--c-text-muted);
    text-align: right;
    font-variant-numeric: tabular-nums;
  }

  /* Mobile: collapse columns */
  @media (max-width: 767px) {
    .essays-table__head {
      grid-template-columns: 50px 1fr 70px;
      gap: 10px;
    }
    .essays-table__head > div:nth-child(3),
    .essays-table__head > div:nth-child(4) { display: none; }

    .essays-table__row {
      grid-template-columns: 50px 1fr 70px;
      gap: 10px;
    }
    .essays-table__tags,
    .essays-table__date { display: none; }
  }
</style>
