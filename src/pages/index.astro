---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects', ({ data }) => data.visible === true);
const featuredProjects = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => (a.data.order || 999) - (b.data.order || 999))
  .slice(0, 2);

const allPosts = await getCollection('blog', ({ data }) => data.visible === true);
const recentPosts = allPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<Layout title="Home">
  <!-- Hero Section -->
  <section class="py-16 lg:py-24">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight mb-5" style="color: var(--c-text)">
          Rodrigo Sasaki
        </h1>

        <h2 class="text-lg md:text-xl mb-4 font-medium" style="color: var(--c-text-secondary)">
          Software Engineer
        </h2>

        <p class="text-base mb-10 leading-relaxed max-w-xl" style="color: var(--c-text-muted)">
          I like thinking about code and about systems. Here I'll share some of my work and my thoughts on software engineering.
        </p>

        <div class="flex flex-wrap gap-3">
          <a
            href="/projects/"
            class="inline-flex items-center px-5 py-2.5 rounded-md text-sm font-medium transition-colors duration-150"
            style="background-color: var(--c-text); color: var(--c-bg)"
          >
            View Projects
            <svg class="ml-2 w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>

          <a
            href="/blog/"
            class="inline-flex items-center px-5 py-2.5 rounded-md text-sm font-medium transition-colors duration-150"
            style="border: 1px solid var(--c-border); color: var(--c-text-secondary)"
          >
            Read Blog
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  <section class="py-16" style="border-top: 1px solid var(--c-border)">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-baseline justify-between mb-10">
        <h2 class="text-2xl font-bold" style="color: var(--c-text)">
          Featured Projects
        </h2>
        <a href="/projects/" class="text-sm transition-colors duration-150" style="color: var(--c-text-muted)">
          View all &rarr;
        </a>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {featuredProjects.map((project, i) => (
          <a href={`/projects/${project.slug}/`} class="group block">
            <article
              class="p-6 rounded-lg transition-all duration-250"
              style={`border: 1px solid var(--c-border); background-color: ${i === 0 ? 'var(--c-bg-alt)' : 'var(--c-bg-card)'}`}
            >
              <h3 class="text-lg font-semibold mb-2 group-hover:opacity-80 transition-colors duration-150" style="color: var(--c-text)">
                {project.data.title}
              </h3>

              <p class="text-sm mb-4 leading-relaxed" style="color: var(--c-text-muted)">
                {project.data.description}
              </p>

              <div class="flex flex-wrap gap-1.5">
                {project.data.tags?.slice(0, 3).map((tag: string) => (
                  <span
                    class="text-xs px-2 py-0.5 rounded"
                    style="background-color: var(--c-tag-bg); color: var(--c-tag-text)"
                  >
                    {tag}
                  </span>
                ))}
              </div>
            </article>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Recent Writing -->
  <section class="py-16" style="border-top: 1px solid var(--c-border)">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-baseline justify-between mb-10">
        <h2 class="text-2xl font-bold" style="color: var(--c-text)">
          Recent Writing
        </h2>
        <a href="/blog/" class="text-sm transition-colors duration-150" style="color: var(--c-text-muted)">
          View all &rarr;
        </a>
      </div>

      <div>
        {recentPosts.map((post) => (
          <a
            href={`/blog/${post.slug}/`}
            class="group block py-5 first:pt-0 last:pb-0"
            style="border-bottom: 1px solid var(--c-border)"
          >
            <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 sm:gap-4">
              <div class="flex-1 min-w-0">
                {post.data.series && (
                  <span class="inline-block text-xs font-medium mr-2" style="color: var(--c-accent)">
                    Series
                  </span>
                )}
                <h3 class="text-base font-medium group-hover:opacity-80 transition-colors duration-150 inline" style="color: var(--c-text)">
                  {post.data.title}
                </h3>
              </div>

              {post.data.date && (
                <time class="text-sm flex-shrink-0 tabular-nums" style="color: var(--c-text-muted)">
                  {new Date(post.data.date).toLocaleDateString('en-US', {
                    month: 'short',
                    day: 'numeric',
                    year: 'numeric'
                  })}
                </time>
              )}
            </div>

            <p class="text-sm mt-1 leading-relaxed line-clamp-1" style="color: var(--c-text-muted)">
              {post.data.description}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Connect Section -->
  <section class="py-16" style="border-top: 1px solid var(--c-border)">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-xl">
        <h2 class="text-2xl font-bold mb-3" style="color: var(--c-text)">
          Let's Connect
        </h2>
        <p class="text-sm mb-6" style="color: var(--c-text-muted)">
          Interested in collaborating or discussing software engineering ideas?
        </p>

        <div class="flex flex-wrap gap-3">
          <a
            href="/cv/"
            class="inline-flex items-center px-4 py-2 text-sm rounded-md font-medium transition-colors duration-150"
            style="background-color: var(--c-tag-bg); color: var(--c-text-secondary)"
          >
            View CV
          </a>

          <a
            href="https://github.com/rodrigopsasaki"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-4 py-2 text-sm rounded-md font-medium transition-colors duration-150"
            style="background-color: var(--c-tag-bg); color: var(--c-text-secondary)"
          >
            <svg class="mr-1.5 w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            GitHub
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
