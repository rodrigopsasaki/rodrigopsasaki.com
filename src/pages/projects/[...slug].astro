---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => data.visible === true);
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: project,
  }));
}

const project = Astro.props;
const { Content } = await project.render();

const hasParent = !!project.data.parent;
const allProjects = await getCollection('projects', ({ data }) => data.visible === true);
const parentProject = hasParent ? (allProjects.find(p => p.slug === project.data.parent) ?? null) : null;
const rootSlug = hasParent && parentProject ? parentProject.slug : project.slug;
const hasEcosystem = allProjects.some(p => p.data.parent === rootSlug);

// Ecosystem siblings (for the left docs-tree sidebar)
const siblings = hasEcosystem ? allProjects.filter(p => p.data.parent === rootSlug) : [];

// Group siblings for the tree view — the design shows category folders
// (web frameworks, data, exporters). We derive groups from tags when present.
function groupForSibling(s: typeof allProjects[number]): string {
  const tags = (s.data.tags ?? []).map(t => t.toLowerCase());
  if (tags.some(t => ['datadog', 'exporter', 'exporters'].includes(t))) return 'exporters';
  if (tags.some(t => ['prisma', 'typeorm', 'database', 'data'].includes(t))) return 'data';
  return 'integrations';
}
const grouped = siblings.reduce<Record<string, typeof siblings>>((acc, s) => {
  const g = groupForSibling(s);
  (acc[g] ||= []).push(s);
  return acc;
}, {});

const breadcrumb = hasParent && parentProject
  ? `${parentProject.slug}/${project.slug}.md`
  : `${project.slug}.md`;
---

<Layout
  title={project.data.title}
  description={project.data.description}
  active="projects"
  statusLeft={`projects/${breadcrumb}`}
  statusCenter={project.data.tags.slice(0, 3).join(' · ')}
>
  <!-- Breadcrumb strip -->
  <div class="project-crumb">
    <a href="/projects/">projects/</a>
    <span aria-hidden="true">›</span>
    {hasParent && parentProject && (
      <>
        <a href={`/projects/${parentProject.slug}/`}>{parentProject.slug}/</a>
        <span aria-hidden="true">›</span>
      </>
    )}
    <span class="project-crumb__current">README.md</span>
  </div>

  <div class="project-grid" data-has-ecosystem={hasEcosystem ? 'true' : 'false'}>
    {hasEcosystem && (
      <aside class="project-aside">
        <div class="project-section-label">{rootSlug} / docs</div>
        <nav class="project-tree" aria-label="Ecosystem navigation">
          <a
            href={`/projects/${rootSlug}/`}
            class="project-tree__row"
            data-active={!hasParent ? 'true' : 'false'}
            data-folder="true"
          >
            ▾ getting-started.md
          </a>

          {Object.entries(grouped).map(([group, items]) => (
            <>
              <div class="project-tree__folder">▾ {group}</div>
              {items.map(s => (
                <a
                  href={`/projects/${s.slug}/`}
                  class="project-tree__row"
                  data-active={project.slug === s.slug ? 'true' : 'false'}
                >
                  &nbsp;&nbsp;&nbsp;{s.slug.replace(`${rootSlug}-`, '').replace(/^.*\//, '')}.md
                </a>
              ))}
            </>
          ))}
        </nav>
      </aside>
    )}

    <article class="project-body">
      <div class="project-body__header">
        <h1 class="project-body__title">{project.data.title}</h1>
        <span class="project-body__meta">MIT · {project.data.tags.find(t => t.toLowerCase() === 'typescript') ? 'TypeScript' : project.data.tags[0]}</span>
      </div>
      <p class="project-body__sub">{project.data.description}</p>

      <div class="project-badges">
        {project.data.tags.slice(0, 4).map(t => (
          <span class="project-badge">{t}</span>
        ))}
        {project.data.github && <a href={project.data.github} class="project-badge project-badge--link" target="_blank" rel="noopener noreferrer">↗ github</a>}
        {project.data.npm && <a href={project.data.npm} class="project-badge project-badge--link" target="_blank" rel="noopener noreferrer">↗ npm</a>}
        {project.data.demo && <a href={project.data.demo} class="project-badge project-badge--link" target="_blank" rel="noopener noreferrer">↗ demo</a>}
      </div>

      <div id="main-content" class="prose max-w-none workshop-prose">
        <Content />
      </div>
    </article>
  </div>
</Layout>

<style>
  .project-crumb {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 20px;
    border-bottom: 1px solid var(--c-border);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    color: var(--c-text-muted);
  }
  .project-crumb a { color: var(--c-text-muted); }
  .project-crumb a:hover { color: var(--c-text); }
  .project-crumb__current { color: var(--c-text); }

  .project-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
  }
  .project-grid[data-has-ecosystem="true"] {
    grid-template-columns: 240px minmax(0, 1fr);
  }
  @media (max-width: 767px) {
    .project-grid[data-has-ecosystem="true"] { grid-template-columns: 1fr; }
    .project-aside { display: none; }
  }

  .project-aside {
    border-right: 1px solid var(--c-border);
    padding: 24px 0;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 12px;
  }
  .project-section-label {
    padding: 0 16px 10px;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--c-text-muted);
  }
  .project-tree { padding: 0 12px; }
  .project-tree__folder {
    padding: 3px 10px;
    color: var(--c-text);
    margin-top: 8px;
  }
  .project-tree__row {
    display: block;
    padding: 3px 10px;
    color: var(--c-text-secondary);
    border-left: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s, background-color 0.15s;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .project-tree__row:hover { color: var(--c-text); }
  .project-tree__row[data-folder="true"] { color: var(--c-text); }
  .project-tree__row[data-active="true"] {
    color: var(--c-text);
    border-left-color: var(--c-accent);
    background: var(--c-bg-card);
  }

  .project-body {
    padding: 40px 56px;
    max-width: 860px;
  }
  @media (max-width: 767px) { .project-body { padding: 32px 20px; } }

  .project-body__header {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 10px;
    flex-wrap: wrap;
  }
  .project-body__title {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-weight: 500;
    font-size: clamp(36px, 5vw, 52px);
    margin: 0;
    letter-spacing: -0.02em;
    color: var(--c-accent);
  }
  .project-body__meta {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 13px;
    color: var(--c-text-muted);
  }
  .project-body__sub {
    font-family: 'Inter', sans-serif;
    font-size: 20px;
    color: var(--c-text-secondary);
    margin: 0 0 20px;
    font-style: italic;
  }

  .project-badges {
    display: flex;
    gap: 8px;
    margin-bottom: 28px;
    flex-wrap: wrap;
  }
  .project-badge {
    padding: 4px 10px;
    background: var(--c-bg-card);
    border: 1px solid var(--c-border);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    color: var(--c-text-secondary);
  }
  .project-badge--link:hover { color: var(--c-accent); border-color: var(--c-accent); }

</style>
