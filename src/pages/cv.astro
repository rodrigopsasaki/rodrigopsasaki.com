---
import Layout from '../layouts/Layout.astro';
import { personalInfo, summary, experience, education, skillCategories, calculateYearsOfExperience } from '../data/cv-data';

function ym(iso: string): string {
  const d = new Date(iso);
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
}

// Group achievements as arrow-bulleted, mono-styled list
const yearsExp = calculateYearsOfExperience(experience[experience.length - 1].startDate);
---

<Layout
  title="CV"
  description="Senior Software Engineer, 15 years of experience."
  active="cv"
  statusLeft="cv/rodrigo-sasaki.yaml"
  statusCenter="YAML · UTF-8"
>
  <!-- Breadcrumb / download -->
  <div class="cv-crumb">
    <span>cv/</span>
    <span aria-hidden="true">›</span>
    <span class="cv-crumb__current">rodrigo-sasaki.yaml</span>
    <div class="cv-crumb__spacer"></div>
    <button type="button" class="cv-crumb__print" onclick="window.print()">download .pdf</button>
  </div>

  <section class="cv-header">
    <h1 class="cv-header__name">
      <span class="cv-header__key">name:</span> {personalInfo.name}
    </h1>
    <div class="cv-header__yaml">
      <div><span class="cv-header__key">role:</span>       Senior Software Engineer</div>
      <div><span class="cv-header__key">years:</span>      <span class="cv-header__accent">{yearsExp}</span></div>
      <div><span class="cv-header__key">location:</span>   {personalInfo.location} · Remote-friendly</div>
      <div>
        <span class="cv-header__key">links:</span>      [
        <a href={personalInfo.github} class="cv-header__link" target="_blank" rel="noopener noreferrer">github</a>,{' '}
        <a href={personalInfo.linkedin} class="cv-header__link" target="_blank" rel="noopener noreferrer">linkedin</a>
        ]
      </div>
    </div>
    <p class="cv-header__bio">{summary}</p>
  </section>

  <div class="cv-grid">
    <div class="cv-main">
      <h2 class="cv-section-heading"># experience</h2>
      {experience.map((e) => (
        <div class="cv-job" data-current={e.endDate === null ? 'true' : 'false'}>
          <div class="cv-job__dot" aria-hidden="true"></div>
          <div class="cv-job__head">
            <span class="cv-job__co">{e.company}</span>
            <span class="cv-job__dot-sep" aria-hidden="true">·</span>
            <span class="cv-job__role">{e.role}</span>
            <div class="cv-job__spacer"></div>
            <span class="cv-job__dates">{ym(e.startDate)} → {e.endDate ? ym(e.endDate) : 'present'}</span>
          </div>
          <div class="cv-job__loc">{e.location}</div>
          <ul class="cv-job__list">
            {e.achievements.map(a => (
              <li class="cv-job__item"><span class="cv-job__arrow" aria-hidden="true">→</span>{a}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="cv-side">
      <h2 class="cv-section-heading"># stack</h2>
      {Object.entries(skillCategories).map(([cat, items]) => (
        <div class="cv-stack">
          <div class="cv-stack__cat">{cat.toLowerCase()}:</div>
          <div class="cv-stack__items">
            {items.map(i => <span class="cv-stack__pill">{i}</span>)}
          </div>
        </div>
      ))}

      <h2 class="cv-section-heading cv-section-heading--second"># education</h2>
      <div class="cv-edu">
        {education.map(ed => (
          <div class="cv-edu__item">
            <div class="cv-edu__inst">{ed.institution}</div>
            <div class="cv-edu__deg">{ed.degree} · {ed.startYear}–{ed.endYear}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</Layout>

<style>
  .cv-crumb {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 20px;
    border-bottom: 1px solid var(--c-border);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    color: var(--c-text-muted);
  }
  .cv-crumb__current { color: var(--c-text-secondary); }
  .cv-crumb__spacer { flex: 1; }
  .cv-crumb__print {
    background: transparent;
    border: 0;
    color: var(--c-accent);
    cursor: pointer;
    font-family: inherit;
    font-size: inherit;
    padding: 0;
  }
  .cv-crumb__print:hover { color: var(--c-accent-hover); }

  .cv-header {
    padding: 48px 56px 32px;
  }
  @media (max-width: 767px) { .cv-header { padding: 32px 20px 16px; } }

  .cv-header__name {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 500;
    margin: 0;
    letter-spacing: -0.018em;
    line-height: 1.1;
    color: var(--c-text);
  }
  .cv-header__key { color: var(--c-text-muted); }
  .cv-header__accent { color: var(--c-accent); }
  .cv-header__yaml {
    margin-top: 12px;
    font-size: 15px;
    color: var(--c-text-secondary);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    line-height: 1.9;
  }
  .cv-header__link { color: var(--c-accent-blue); }
  .cv-header__link:hover { color: var(--c-accent); }
  .cv-header__bio {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    color: var(--c-text);
    margin-top: 24px;
    max-width: 700px;
    line-height: 1.6;
  }

  .cv-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 40px;
    padding: 24px 56px 56px;
  }
  @media (max-width: 1024px) { .cv-grid { gap: 28px; } }
  @media (max-width: 767px) {
    .cv-grid { grid-template-columns: 1fr; padding: 16px 20px 40px; }
  }

  .cv-section-heading {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 14px;
    color: var(--c-text-muted);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 500;
    margin: 0 0 16px;
  }
  .cv-section-heading--second { margin-top: 32px; }

  /* ───── Experience timeline ───────────────────────────────── */
  .cv-job {
    position: relative;
    border-left: 2px solid var(--c-border);
    padding-left: 20px;
    margin-bottom: 28px;
  }
  .cv-job[data-current="true"] { border-left-color: var(--c-accent); }
  .cv-job__dot {
    position: absolute;
    left: -5px;
    top: 6px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--c-text-muted);
  }
  .cv-job[data-current="true"] .cv-job__dot { background: var(--c-accent); }

  .cv-job__head {
    display: flex;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
  }
  .cv-job__co {
    font-size: 17px;
    font-weight: 500;
    color: var(--c-text);
  }
  .cv-job__dot-sep { color: var(--c-text-muted); font-size: 12px; }
  .cv-job__role {
    font-size: 13px;
    color: var(--c-text-secondary);
    font-family: 'Inter', sans-serif;
  }
  .cv-job__spacer { flex: 1; }
  .cv-job__dates {
    font-size: 11px;
    color: var(--c-text-muted);
    font-variant-numeric: tabular-nums;
  }
  .cv-job__loc {
    font-size: 11px;
    color: var(--c-text-muted);
    margin-top: 2px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
  }
  .cv-job__list {
    margin: 10px 0 0;
    padding: 0;
    list-style: none;
    font-family: 'Inter', sans-serif;
    font-size: 13.5px;
    color: var(--c-text-secondary);
    line-height: 1.6;
  }
  .cv-job__item {
    margin-bottom: 4px;
    padding-left: 16px;
    position: relative;
  }
  .cv-job__arrow {
    position: absolute;
    left: 0;
    color: var(--c-accent);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
  }

  /* ───── Side: stack + education ───────────────────────────── */
  .cv-stack { margin-bottom: 20px; font-family: 'JetBrains Mono', ui-monospace, monospace; }
  .cv-stack__cat {
    font-size: 12px;
    color: var(--c-text-muted);
    margin-bottom: 6px;
  }
  .cv-stack__items { display: flex; flex-wrap: wrap; gap: 6px; }
  .cv-stack__pill {
    font-size: 12px;
    padding: 3px 10px;
    background: var(--c-bg-card);
    border: 1px solid var(--c-border);
    color: var(--c-text);
  }

  .cv-edu__item {
    font-size: 13px;
    line-height: 1.7;
    margin-bottom: 14px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
  }
  .cv-edu__inst { color: var(--c-text); }
  .cv-edu__deg  { color: var(--c-text-muted); font-size: 12px; }

  @media print {
    .workshop-nav, .workshop-status, .cv-crumb { display: none !important; }
    .cv-header, .cv-grid { padding: 0 !important; }
    body { background: white !important; color: black !important; }
  }
</style>
