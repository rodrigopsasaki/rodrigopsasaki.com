---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchComponent from '../components/Search.astro';
---

<BaseLayout title="Search">
  <div class="min-h-screen">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <!-- Header -->
      <div class="mb-10">
        <h1 class="text-3xl font-bold text-gray-900 dark:text-monokai-text mb-2">
          Search
        </h1>
        <p class="text-sm text-gray-500 dark:text-monokai-muted">
          Find posts, projects, and content by title, tags, or keywords.
        </p>
      </div>

      <!-- Search Component -->
      <div class="max-w-xl">
        <SearchComponent />
      </div>

      <!-- Search Tips -->
      <div class="max-w-xl mt-10">
        <h2 class="text-xs font-semibold text-gray-700 dark:text-monokai-text uppercase tracking-wide mb-3">
          Tips
        </h2>
        <div class="space-y-2 text-sm text-gray-500 dark:text-monokai-muted">
          <p>Search is fuzzy — "arch" will find "architecture" posts.</p>
          <p>Click suggested tags to explore related content.</p>
          <p>Press <kbd class="px-1 py-0.5 text-xs font-mono bg-gray-100 dark:bg-monokai-border rounded">/</kbd> to focus the search from anywhere.</p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  kbd {
    font-family: 'JetBrains Mono', monospace;
  }
</style>
