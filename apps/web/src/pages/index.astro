---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n';
import { getCollection } from 'astro:content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Get featured content
const allProjects = await getCollection('en/projects', ({ data }) => data.visible === true);
const featuredProjects = allProjects
  .filter(project => project.data.featured)
  .sort((a, b) => (a.data.order || 999) - (b.data.order || 999))
  .slice(0, 2);

const allPosts = await getCollection('en/blog', ({ data }) => data.visible === true);
const recentPosts = allPosts
  .sort((a, b) => new Date(b.data.date || '').getTime() - new Date(a.data.date || '').getTime())
  .slice(0, 3);
---

<BaseLayout title={t.nav.home}>
  <!-- Hero Section — left-aligned, asymmetric -->
  <section class="py-16 lg:py-24">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-gray-900 dark:text-monokai-text mb-5">
          {t.home.title}
        </h1>

        <h2 class="text-lg md:text-xl text-gray-600 dark:text-monokai-muted mb-4 font-medium">
          {t.home.subtitle}
        </h2>

        <p class="text-base text-gray-500 dark:text-monokai-muted mb-10 leading-relaxed max-w-xl">
          {t.home.description}
        </p>

        <!-- Quick Actions — left aligned, not centered -->
        <div class="flex flex-wrap gap-3">
          <a href={getLocalizedPath('/projects/', lang)}
             class="inline-flex items-center px-5 py-2.5 bg-gray-900 dark:bg-monokai-text text-white dark:text-monokai-bg rounded-md text-sm font-medium hover:bg-gray-700 dark:hover:bg-gray-300 transition-colors duration-150">
            {t.home.cta.viewProjects}
            <svg class="ml-2 w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>

          <a href={getLocalizedPath('/blog/', lang)}
             class="inline-flex items-center px-5 py-2.5 border border-gray-300 dark:border-monokai-border text-gray-700 dark:text-monokai-muted rounded-md text-sm font-medium hover:bg-gray-100 dark:hover:bg-monokai-border/20 transition-colors duration-150">
            {t.home.cta.readBlog}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Projects — editorial layout with different card sizes -->
  <section class="py-16 border-t border-gray-200/60 dark:border-monokai-border/40">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-baseline justify-between mb-10">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-monokai-text">
          Featured Projects
        </h2>
        <a href={getLocalizedPath('/projects/', lang)}
           class="text-sm text-gray-500 dark:text-monokai-muted hover:text-gray-800 dark:hover:text-monokai-text transition-colors duration-150">
          View all &rarr;
        </a>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {featuredProjects.map((project, i) => (
          <a href={getLocalizedPath(`/projects/${project.slug}/`, lang)} class="group block">
            <article class={`p-6 rounded-lg border border-gray-200/80 dark:border-monokai-border/60 hover:border-gray-300 dark:hover:border-monokai-muted/40 transition-all duration-250 ${i === 0 ? 'bg-gray-50 dark:bg-monokai-surface' : 'bg-white dark:bg-monokai-bg'}`}>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-monokai-text mb-2 group-hover:text-primary-700 dark:group-hover:text-monokai-yellow transition-colors duration-150">
                {project.data.title}
              </h3>

              <p class="text-sm text-gray-500 dark:text-monokai-muted mb-4 leading-relaxed">
                {project.data.description}
              </p>

              <div class="flex flex-wrap gap-1.5">
                {project.data.tags?.slice(0, 3).map((tag: string) => (
                  <span class="text-xs px-2 py-0.5 bg-gray-100 dark:bg-monokai-border/30 text-gray-600 dark:text-monokai-muted rounded">
                    {tag}
                  </span>
                ))}
              </div>
            </article>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Recent Blog Posts — minimal list style, no cards -->
  <section class="py-16 border-t border-gray-200/60 dark:border-monokai-border/40">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-baseline justify-between mb-10">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-monokai-text">
          Recent Writing
        </h2>
        <a href={getLocalizedPath('/blog/', lang)}
           class="text-sm text-gray-500 dark:text-monokai-muted hover:text-gray-800 dark:hover:text-monokai-text transition-colors duration-150">
          View all &rarr;
        </a>
      </div>

      <div class="divide-y divide-gray-200/80 dark:divide-monokai-border/40">
        {recentPosts.map((post) => (
          <a href={getLocalizedPath(`/blog/${post.slug}/`, lang)} class="group block py-5 first:pt-0 last:pb-0">
            <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 sm:gap-4">
              <div class="flex-1 min-w-0">
                {post.data.series && (
                  <span class="inline-block text-xs font-medium text-primary-700 dark:text-monokai-yellow mr-2">
                    Series
                  </span>
                )}
                <h3 class="text-base font-medium text-gray-800 dark:text-monokai-text group-hover:text-primary-700 dark:group-hover:text-monokai-yellow transition-colors duration-150 inline">
                  {post.data.title}
                </h3>
              </div>

              {post.data.date && (
                <time class="text-sm text-gray-400 dark:text-monokai-muted flex-shrink-0 tabular-nums">
                  {new Date(post.data.date).toLocaleDateString('en-US', {
                    month: 'short',
                    day: 'numeric',
                    year: 'numeric'
                  })}
                </time>
              )}
            </div>

            <p class="text-sm text-gray-500 dark:text-monokai-muted mt-1 leading-relaxed line-clamp-1">
              {post.data.description}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Connect Section — compact, not a big hero -->
  <section class="py-16 border-t border-gray-200/60 dark:border-monokai-border/40">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-xl">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-monokai-text mb-3">
          Let's Connect
        </h2>
        <p class="text-sm text-gray-500 dark:text-monokai-muted mb-6">
          Interested in collaborating or discussing software engineering ideas?
        </p>

        <div class="flex flex-wrap gap-3">
          <a href={getLocalizedPath('/cv/', lang)}
             class="inline-flex items-center px-4 py-2 text-sm bg-gray-100 dark:bg-monokai-border/30 text-gray-700 dark:text-monokai-muted rounded-md font-medium hover:bg-gray-200 dark:hover:bg-monokai-border/50 transition-colors duration-150">
            View CV
          </a>

          <a href="https://github.com/rodrigopsasaki"
             target="_blank"
             rel="noopener noreferrer"
             class="inline-flex items-center px-4 py-2 text-sm bg-gray-100 dark:bg-monokai-border/30 text-gray-700 dark:text-monokai-muted rounded-md font-medium hover:bg-gray-200 dark:hover:bg-monokai-border/50 transition-colors duration-150">
            <svg class="mr-1.5 w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            GitHub
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
