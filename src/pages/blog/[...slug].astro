---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getSeriesNavigation } from '../../utils/series';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.visible === true);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

const post = Astro.props;
const { Content, headings } = await post.render();

const allPosts = await getCollection('blog', ({ data }) => data.visible === true);
const { prev: prevPost, next: nextPost, seriesPosts, isInSeries, seriesName } = getSeriesNavigation(allPosts, post);

const wordCount = post.body.split(/\s+/).length;
const readingTime = Math.ceil(wordCount / 200);

const articleData = {
  publishedTime: new Date(post.data.date).toISOString(),
  modifiedTime: post.data.lastModified
    ? new Date(post.data.lastModified).toISOString()
    : new Date(post.data.date).toISOString(),
  author: post.data.author || 'Rodrigo Sasaki',
  tags: post.data.tags || [],
};

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  author: { '@type': 'Person', name: articleData.author, url: 'https://rodrigopsasaki.com' },
  datePublished: articleData.publishedTime,
  dateModified: articleData.modifiedTime,
  publisher: { '@type': 'Person', name: 'Rodrigo Sasaki', url: 'https://rodrigopsasaki.com' },
  mainEntityOfPage: { '@type': 'WebPage', '@id': Astro.url },
  keywords: articleData.tags.join(', '),
  articleSection: 'Technology',
  wordCount,
  timeRequired: `PT${readingTime}M`,
};

// Build an outline from H2s (numbered 01..N) for the TOC.
const h2s = headings.filter(h => h.depth === 2);
const outline = h2s.map((h, i) => ({ n: String(i + 1).padStart(2, '0'), text: h.text, slug: h.slug }));

function formatIso(iso: string): string {
  return new Date(iso).toISOString().slice(0, 10);
}
---

<Layout
  title={post.data.title}
  description={post.data.description}
  article={articleData}
  active="essays"
  statusLeft={`essays/${post.slug}.md`}
  statusCenter={`${wordCount.toLocaleString()} words · ${readingTime} min`}
>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} is:inline />

  <!-- Breadcrumb strip -->
  <div class="essay-crumb">
    <a href="/blog/">essays/</a>
    <span aria-hidden="true">›</span>
    <span class="essay-crumb__current">{post.slug}.md</span>
    <div class="essay-crumb__spacer"></div>
    <span>{wordCount.toLocaleString()} words</span>
    <span>·</span>
    <span>{readingTime} min</span>
  </div>

  <div class="essay-grid">
    <!-- Left: TOC + frontmatter -->
    <aside class="essay-aside essay-aside--left">
      <div class="essay-section-label">Outline</div>
      <nav class="essay-outline" aria-label="Table of contents">
        {outline.length === 0 ? (
          <div class="essay-outline__empty">(no sections)</div>
        ) : (
          outline.map((o, i) => (
            <a href={`#${o.slug}`} class="essay-outline__row" data-active={i === 0 ? 'true' : 'false'}>
              <span class="essay-outline__n">{o.n}</span>
              <span>{o.text}</span>
            </a>
          ))
        )}
      </nav>

      <div class="essay-section-divider"></div>
      <div class="essay-section-label">Frontmatter</div>
      <div class="essay-frontmatter">
        <div><span class="essay-frontmatter__key">date:</span>   {formatIso(post.data.date)}</div>
        <div><span class="essay-frontmatter__key">author:</span> {articleData.author}</div>
        <div>
          <span class="essay-frontmatter__key">tags:</span>
          {post.data.tags.length === 0 ? ' []' : (
            <> [{post.data.tags.map((t, i) => (
              <><span class="essay-frontmatter__val">{t}</span>{i < post.data.tags.length - 1 && ', '}</>
            ))}]</>
          )}
        </div>
        <div><span class="essay-frontmatter__key">series:</span> {post.data.series ?? 'null'}</div>
      </div>

      {isInSeries && (
        <>
          <div class="essay-section-divider"></div>
          <div class="essay-section-label">{seriesName} · series</div>
          <nav class="essay-series" aria-label="Series navigation">
            {seriesPosts.map(sp => (
              <a
                href={`/blog/${sp.slug}/`}
                class="essay-series__row"
                data-current={sp.id === post.id ? 'true' : 'false'}
              >
                <span class="essay-series__order">{String((sp.data.seriesOrder ?? 0) + 1).padStart(2, '0')}</span>
                <span>{sp.data.title}</span>
              </a>
            ))}
          </nav>
        </>
      )}
    </aside>

    <!-- Center: article -->
    <article class="essay-body">
      <div class="essay-body__kicker">// {post.slug}.md · {new Date(post.data.date).getFullYear()}</div>

      <h1 class="essay-body__title">{post.data.title}</h1>
      <div class="essay-body__subtitle">{post.data.description}</div>

      <div class="essay-body__rule"></div>

      <div class="prose max-w-none workshop-prose">
        <Content />
      </div>

      {(prevPost || nextPost) && (
        <div class="essay-next">
          <div class="essay-next__row">
            {prevPost ? (
              <a href={`/blog/${prevPost.slug}/`} class="essay-next__link">
                <div class="essay-next__dir">← previous</div>
                <div class="essay-next__title">{prevPost.data.title}</div>
              </a>
            ) : <div></div>}
            {nextPost ? (
              <a href={`/blog/${nextPost.slug}/`} class="essay-next__link essay-next__link--right">
                <div class="essay-next__dir">next →</div>
                <div class="essay-next__title">{nextPost.data.title}</div>
              </a>
            ) : <div></div>}
          </div>
        </div>
      )}
    </article>

    <!-- Right: margin meta -->
    <aside class="essay-aside essay-aside--right">
      <div>
        <div class="essay-section-label">Reading</div>
        <div class="essay-reading">
          <div class="essay-reading__bar"><div class="essay-reading__fill" id="reading-fill"></div></div>
          <div class="essay-reading__meta" id="reading-meta">{readingTime} min total</div>
        </div>
      </div>

      {post.data.tags.length > 0 && (
        <div>
          <div class="essay-section-label">Tags</div>
          <div class="essay-tags">
            {post.data.tags.map(t => <span class="essay-tags__pill">#{t}</span>)}
          </div>
        </div>
      )}

      <div>
        <div class="essay-section-label">Share</div>
        <div class="essay-share">rodrigopsasaki.com/blog/<br/>{post.slug}</div>
      </div>
    </aside>
  </div>
</Layout>

<script>
  // Reading progress + active outline highlighting
  function initEssayReading() {
    const fill = document.getElementById('reading-fill') as HTMLElement | null;
    const meta = document.getElementById('reading-meta') as HTMLElement | null;
    const article = document.querySelector<HTMLElement>('.essay-body');
    const outlineLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.essay-outline__row'));
    const headings = outlineLinks
      .map(a => document.getElementById(a.hash.slice(1)))
      .filter((el): el is HTMLElement => !!el);

    function update() {
      if (!article) return;
      const rect = article.getBoundingClientRect();
      const total = rect.height - window.innerHeight;
      const scrolled = Math.min(Math.max(-rect.top, 0), total);
      const pct = total > 0 ? scrolled / total : 0;
      if (fill) fill.style.width = `${Math.round(pct * 100)}%`;
      if (meta) meta.textContent = `${Math.round(pct * 100)}% read`;

      // Active outline
      const y = window.scrollY + 140;
      let activeIdx = -1;
      for (let i = 0; i < headings.length; i++) {
        if (headings[i].offsetTop <= y) activeIdx = i;
      }
      outlineLinks.forEach((a, i) => {
        a.dataset.active = i === activeIdx ? 'true' : 'false';
      });
    }

    update();
    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);

    // Open external prose links in new tabs
    document.querySelectorAll<HTMLAnchorElement>('.workshop-prose a').forEach(a => {
      if (a.hasAttribute('target')) return;
      const href = a.getAttribute('href') || '';
      if (href.startsWith('#') || href.startsWith('/')) return;
      a.setAttribute('target', '_blank');
      a.setAttribute('rel', 'noopener noreferrer');
    });
  }

  document.addEventListener('DOMContentLoaded', initEssayReading);
  document.addEventListener('astro:page-load', initEssayReading);
</script>

<style>
  .essay-crumb {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 20px;
    border-bottom: 1px solid var(--c-border);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    color: var(--c-text-muted);
    overflow-x: auto;
    scrollbar-width: none;
  }
  .essay-crumb::-webkit-scrollbar { display: none; }
  .essay-crumb__spacer { flex: 1; }
  .essay-crumb a { color: var(--c-text-muted); }
  .essay-crumb a:hover { color: var(--c-text); }
  .essay-crumb__current { color: var(--c-text-secondary); }

  .essay-grid {
    display: grid;
    grid-template-columns: 260px minmax(0, 1fr) 240px;
    min-height: 0;
  }
  @media (max-width: 1024px) {
    .essay-grid { grid-template-columns: 240px minmax(0, 1fr); }
    .essay-aside--right { display: none !important; }
  }
  @media (max-width: 767px) {
    .essay-grid { grid-template-columns: 1fr; }
    .essay-aside--left { display: none !important; }
    .essay-aside--right { display: none !important; }
  }

  /* ───── Asides ────────────────────────────────────────────── */
  .essay-aside {
    padding: 24px 0;
    overflow-y: auto;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
  }
  .essay-aside--left  { border-right: 1px solid var(--c-border); }
  .essay-aside--right {
    border-left: 1px solid var(--c-border);
    padding: 24px 20px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    font-size: 12px;
    color: var(--c-text-secondary);
  }

  .essay-section-label {
    padding: 0 20px 10px;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--c-text-muted);
  }
  .essay-aside--right .essay-section-label { padding: 0 0 8px; }
  .essay-section-divider {
    border-top: 1px solid var(--c-border);
    margin: 24px 0 14px;
  }

  .essay-outline { padding: 0 12px; font-size: 12px; }
  .essay-outline__empty {
    padding: 6px 10px;
    color: var(--c-text-muted);
    font-size: 11px;
    font-style: italic;
  }
  .essay-outline__row {
    display: flex;
    gap: 10px;
    padding: 6px 10px;
    color: var(--c-text-secondary);
    border-left: 2px solid transparent;
    margin-bottom: 2px;
    transition: color 0.15s, border-color 0.15s;
  }
  .essay-outline__row:hover { color: var(--c-text); }
  .essay-outline__row[data-active="true"] {
    color: var(--c-text);
    border-left-color: var(--c-accent);
  }
  .essay-outline__n {
    color: var(--c-text-muted);
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }

  .essay-frontmatter {
    padding: 0 20px;
    font-size: 11px;
    line-height: 1.9;
    color: var(--c-text-secondary);
  }
  .essay-frontmatter__key { color: var(--c-text-muted); }
  .essay-frontmatter__val { color: var(--c-accent); }

  .essay-series { padding: 0 12px; font-size: 12px; }
  .essay-series__row {
    display: flex;
    gap: 10px;
    padding: 6px 10px;
    color: var(--c-text-secondary);
    border-left: 2px solid transparent;
    margin-bottom: 2px;
  }
  .essay-series__row:hover { color: var(--c-text); }
  .essay-series__row[data-current="true"] {
    color: var(--c-text);
    border-left-color: var(--c-accent);
    background: var(--c-accent-muted);
  }
  .essay-series__order {
    color: var(--c-text-muted);
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }

  /* ───── Article body ──────────────────────────────────────── */
  .essay-body {
    padding: 48px 56px;
    max-width: 780px;
    margin: 0 auto;
    /* Grid items default to min-width:auto, which preserves min-content size.
     * That lets wide children (a code block) push the grid cell past the
     * viewport. min-width:0 lets the cell shrink; overflow-x:clip stops
     * oversized children (the code block) from re-inflating the article. */
    min-width: 0;
    width: 100%;
    overflow-x: clip;
  }
  @media (max-width: 767px) { .essay-body { padding: 32px 20px; } }

  .essay-body__kicker {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 11px;
    color: var(--c-text-muted);
    margin-bottom: 20px;
  }
  .essay-body__title {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-weight: 500;
    font-size: clamp(22px, 5vw, 40px);
    line-height: 1.15;
    letter-spacing: -0.018em;
    margin: 0;
    color: var(--c-text);
    text-wrap: balance;
    /* Let long words break rather than overflow on narrow viewports. */
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .essay-body__subtitle {
    margin-top: 14px;
    font-size: 14px;
    color: var(--c-text-secondary);
    font-style: italic;
    font-family: 'Inter', sans-serif;
    overflow-wrap: break-word;
  }
  .essay-body__rule {
    height: 1px;
    background: var(--c-border);
    margin: 32px 0;
  }

  /* ───── Next / prev ───────────────────────────────────────── */
  .essay-next {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--c-border);
  }
  .essay-next__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .essay-next__link {
    padding: 14px 16px;
    border: 1px solid var(--c-border);
    background: var(--c-bg-card);
    transition: border-color 0.15s;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
  }
  .essay-next__link:hover { border-color: var(--c-accent); }
  .essay-next__link--right { text-align: right; }
  .essay-next__dir {
    font-size: 11px;
    color: var(--c-text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .essay-next__title {
    font-size: 14px;
    color: var(--c-text);
    font-family: 'Inter', sans-serif;
  }

  /* ───── Right rail widgets ────────────────────────────────── */
  .essay-reading__bar {
    position: relative;
    height: 4px;
    background: var(--c-border-soft);
    margin-bottom: 8px;
  }
  .essay-reading__fill {
    position: absolute;
    inset: 0 auto 0 0;
    width: 0%;
    background: var(--c-accent);
    transition: width 0.1s;
  }
  .essay-reading__meta {
    font-size: 11px;
    color: var(--c-text-muted);
  }

  .essay-tags {
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-size: 12px;
  }
  .essay-tags__pill { color: var(--c-text-secondary); }

  .essay-share {
    font-size: 11px;
    color: var(--c-text-muted);
    line-height: 1.6;
    word-break: break-word;
  }
</style>
